# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Auth (use openssl rand -hex 64 to generate)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Database
DATABASE_URL=postgres://safeguard:safeguard@localhost:5432/safeguardmeet

# TURN / SFU (optional)
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Storage (S3-compatible, optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
